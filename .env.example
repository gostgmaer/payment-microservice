# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3302
APP_NAME=payment-microservice
API_PREFIX=api/v1

# ─── Database ──────────────────────────────────────────────────# Shared single postgres — schema separation across services:
#   IAM          → ?schema=iam     (Prisma, auto-creates schema on db push)
#   payment      → ?schema=payment (Prisma, auto-creates schema on db push)
#   ai-comm      → public schema   (TypeORM synchronize)
#
# Local dev uses shared postgres host mapping on port 3350.
# Docker (easydev/docker-compose.yml) injects core:5432 on easydev-net.
DATABASE_URL=postgresql://postgres:password@localhost:3350/postgres?schema=payment

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=3351
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────────
# This service does NOT issue tokens — it only VERIFIES them.
# Tokens are issued exclusively by multi-tannet-auth-services (IAM).
#
# Option A — RS256 asymmetric (recommended for production):
#   Copy JWT_PUBLIC_KEY from multi-tannet-auth-services/.env (base64-encoded SPKI PEM).
JWT_PUBLIC_KEY=
# IAM_JWT_PUBLIC_KEY=                         # legacy alias for JWT_PUBLIC_KEY
#
# Option B — HS256 shared secret (dev/single-node only):
#   Must equal JWT_SECRET in multi-tannet-auth-services.
JWT_SECRET=CHANGE_ME_must_match_JWT_SECRET_in_iam_service_min_32_chars
#
# Must exactly match JWT_ISSUER in multi-tannet-auth-services.
JWT_ISSUER=https://iam-service.easydev.in
JWT_AUDIENCE=dashboard-app

# ─── IAM Service ────────────────────────────────────────────────
# Base URL of multi-tannet-auth-services (no trailing slash).
# Used for startup permission registration and GST configuration.
# IAM default local port: 3304
IAM_SERVICE_URL=http://localhost:3304
# API key with permission:manage scope registered in multi-tannet-auth-services.
# Required for startup permission registration via POST /api/v1/iam/rbac/permissions/register.
# Generate in IAM admin: POST /api/v1/iam/api-keys
IAM_SERVICE_API_KEY=CHANGE_ME_iam_api_key_with_permission_manage_scope
# SHA-256 hex digest of the plaintext API key sent by web-agency-backend-api.
# Generate the pair:
#   node -e "const k=require('crypto').randomBytes(32).toString('hex'); console.log('KEY='+k+'\nHASH='+require('crypto').createHash('sha256').update(k).digest('hex'))"
# Set PAYMENT_SERVICE_API_KEY=KEY in web-agency-backend-api, API_KEY_HASH=HASH here.
API_KEY_HASH=sha256-hex-hash-of-your-plaintext-api-key

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2024-04-10
STRIPE_ENABLED=false

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_ENABLED=false

# ─── Cash ───────────────────────────────────────────────────────
CASH_ENABLED=true

# ─── Payment Config ────────────────────────────────────────────
PAYMENT_ATTEMPT_EXPIRY_MINUTES=15
MAX_RETRY_ATTEMPTS=3
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400

# ─── Subscription ──────────────────────────────────────────────
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_MAX_RETRY_ATTEMPTS=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ─── Throttle (Webhook) ────────────────────────────────────────
WEBHOOK_RATE_LIMIT_MAX=50
WEBHOOK_RATE_LIMIT_TTL=60
ENABLE_RATE_LIMIT=false

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_LOGGING=true
ENABLE_PINO_LOGGING=false                 # legacy alias for ENABLE_LOGGING (structured/pino output)

# ─── BullMQ Concurrency ────────────────────────────────────────
PAYMENT_QUEUE_CONCURRENCY=5
REFUND_QUEUE_CONCURRENCY=3
SUBSCRIPTION_QUEUE_CONCURRENCY=5

# ─── Reconciliation Cron ───────────────────────────────────────
RECONCILIATION_CRON=0 2 * * *

# ─── Feature Flags ─────────────────────────────────────────────
FEATURE_MULTI_CURRENCY=false
FEATURE_FAILOVER_ENABLED=true
FEATURE_RECONCILIATION_ENABLED=true

# ─── BullMQ (async job queues) ─────────────────────────────────
# Set to false to disable all async queues (subscription renewal,
# payment/refund retry). All operations become synchronous.
# Useful for local dev, testing, or small deployments.
BULLMQ_ENABLED=true
