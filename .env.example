# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=payment-microservice
API_PREFIX=api/v1

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://payment_user:payment_pass@localhost:5432/postgres?schema=payment

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────────
# This service does NOT issue tokens — it only VERIFIES them.
# Must equal JWT_SECRET in multi-tannet-auth-services (the IAM service that issues all tokens).
JWT_SECRET=copy-the-exact-JWT_SECRET-from-multi-tannet-auth-services

# ─── API Key (for service-to-service auth) ─────────────────────
# SHA-256 hex digest of the plaintext API key sent by web-agency-backend-api.
# Generate the pair:
#   node -e "const k=require('crypto').randomBytes(32).toString('hex'); console.log('KEY='+k+'\nHASH='+require('crypto').createHash('sha256').update(k).digest('hex'))"
# Set PAYMENT_SERVICE_API_KEY=KEY in web-agency-backend-api, API_KEY_HASH=HASH here.
API_KEY_HASH=sha256-hex-hash-of-your-plaintext-api-key

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2024-04-10
STRIPE_ENABLED=true

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_ENABLED=true

# ─── Payment Config ────────────────────────────────────────────
PAYMENT_ATTEMPT_EXPIRY_MINUTES=15
MAX_RETRY_ATTEMPTS=3
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400

# ─── Subscription ──────────────────────────────────────────────
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_MAX_RETRY_ATTEMPTS=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ─── Throttle (Webhook) ────────────────────────────────────────
WEBHOOK_RATE_LIMIT_MAX=50
WEBHOOK_RATE_LIMIT_TTL=60

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ─── BullMQ Concurrency ────────────────────────────────────────
PAYMENT_QUEUE_CONCURRENCY=5
REFUND_QUEUE_CONCURRENCY=3
SUBSCRIPTION_QUEUE_CONCURRENCY=5

# ─── Reconciliation Cron ───────────────────────────────────────
RECONCILIATION_CRON=0 2 * * *

# ─── Feature Flags ─────────────────────────────────────────────
FEATURE_MULTI_CURRENCY=false
FEATURE_FAILOVER_ENABLED=true
FEATURE_RECONCILIATION_ENABLED=true

# ─── BullMQ (async job queues) ─────────────────────────────────
# Set to false to disable all async queues (subscription renewal,
# payment/refund retry). All operations become synchronous.
# Useful for local dev, testing, or small deployments.
BULLMQ_ENABLED=true
