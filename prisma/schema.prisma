// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Payment + Billing + Subscription Microservice
//
// Design decisions:
//  • BigInt for ALL monetary amounts (stored in smallest currency unit: paise/cents)
//    to avoid floating-point rounding errors.
//  • JSONB metadata columns for extensible provider-specific data.
//  • Partial unique index (raw SQL migration) enforces only ONE SUCCESS per
//    transaction (idempotency at DB level).
//  • Soft-delete via status enums rather than hard deletes (auditability).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOID
}

enum Provider {
  STRIPE
  RAZORPAY
}

enum AttemptStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum EntryType {
  PAYMENT
  REFUND
  FEE
  ADJUSTMENT
  TAX
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  FAILED
  VOID
}

enum PlanInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum CycleStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  SKIPPED
}

// ─── Core Models ─────────────────────────────────────────────────────────────

/// Source of truth for a payment. One transaction per customer order.
model Transaction {
  id             String            @id @default(uuid())
  /// Tenant identifier — all financial data is scoped per tenant
  tenantId       String
  /// External order identifier — unique per tenant
  orderId        String
  /// Caller-supplied idempotency key (SHA-256 hash stored) — unique per tenant
  idempotencyKey String
  customerId     String
  amount         BigInt            // stored in smallest unit (paise / cents)
  currency       String            @default("INR")
  status         TransactionStatus @default(PENDING)
  invoiceId      String?
  /// Provider-agnostic metadata (provider responses, custom fields)
  metadata       Json?             @db.JsonB
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  invoice       Invoice?         @relation(fields: [invoiceId], references: [id])
  attempts      PaymentAttempt[]
  ledgerEntries LedgerEntry[]
  refunds       Refund[]
  auditLogs     AuditLog[]

  @@unique([tenantId, orderId])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([status])
  @@index([createdAt])
}

/// One payment attempt per provider. Multiple attempts allowed per transaction.
/// DB-level partial unique index ensures only one SUCCESS per transaction.
model PaymentAttempt {
  id              String        @id @default(uuid())
  transactionId   String
  provider        Provider
  /// payment method: card | upi | netbanking | wallet
  method          String
  /// Provider's internal order/payment-intent ID
  providerOrderId String?
  /// Stripe client_secret returned to frontend
  clientSecret    String?
  status          AttemptStatus @default(PENDING)
  amount          BigInt
  currency        String
  metadata        Json?         @db.JsonB
  failureReason   String?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  transaction Transaction  @relation(fields: [transactionId], references: [id])
  webhookLogs WebhookLog[]

  @@index([transactionId])
  @@index([providerOrderId])
  @@index([status])
  // NOTE: partial unique index created via raw SQL migration:
  // CREATE UNIQUE INDEX unique_success_per_transaction
  //   ON "PaymentAttempt" ("transactionId")
  //   WHERE status = 'SUCCESS';
}

/// Double-entry ledger. Every financial event creates exactly two entries
/// (a debit and a credit) — immutable, never updated.
model LedgerEntry {
  id            String    @id @default(uuid())
  tenantId      String
  transactionId String
  type          EntryType
  /// Account being debited  (e.g. "ACCOUNTS_RECEIVABLE")
  debitAccount  String
  /// Account being credited (e.g. "REVENUE")
  creditAccount String
  amount        BigInt
  currency      String
  description   String
  metadata      Json?     @db.JsonB
  createdAt     DateTime  @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
  @@index([createdAt])
}

/// Raw webhook payload log — written before processing to ensure idempotency.
model WebhookLog {
  id          String    @id @default(uuid())
  provider    Provider
  eventType   String
  /// Provider-assigned event ID — unique constraint prevents re-processing
  eventId     String    @unique
  attemptId   String?
  payload     Json      @db.JsonB
  signature   String
  isVerified  Boolean   @default(false)
  isProcessed Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  attempt PaymentAttempt? @relation(fields: [attemptId], references: [id])

  @@index([provider, eventType])
  @@index([isProcessed])
}

/// Refund record — linked to the original transaction.
model Refund {
  id               String       @id @default(uuid())
  tenantId         String
  transactionId    String
  amount           BigInt
  currency         String
  reason           String?
  status           RefundStatus @default(PENDING)
  providerRefundId String?
  metadata         Json?        @db.JsonB
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
}

// ─── Billing Models ──────────────────────────────────────────────────────────

/// Invoice must always be created before a payment is initiated.
model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  invoiceNumber String
  customerId    String
  status        InvoiceStatus @default(DRAFT)
  subtotal      BigInt        // sum of item amounts before tax
  taxAmount     BigInt        // total tax (CGST + SGST or IGST)
  totalAmount   BigInt        // subtotal + taxAmount
  currency      String        @default("INR")
  dueDate       DateTime?
  paidAt        DateTime?
  metadata      Json?         @db.JsonB
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items        InvoiceItem[]
  transactions Transaction[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([status])
}

/// Line items within an invoice — includes GST breakdown.
model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitAmount  BigInt   // per-unit price in smallest currency unit
  amount      BigInt   // quantity × unitAmount
  /// GST rates stored as Decimal (percentage, e.g. 9.00 for 9%)
  cgstRate    Decimal? @db.Decimal(5, 2)
  sgstRate    Decimal? @db.Decimal(5, 2)
  igstRate    Decimal? @db.Decimal(5, 2)
  /// GST amounts in smallest currency unit
  cgstAmount  BigInt?
  sgstAmount  BigInt?
  igstAmount  BigInt?
  metadata    Json?    @db.JsonB

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

// ─── Subscription Models ─────────────────────────────────────────────────────

/// Subscription plan definition.
/// Plans are grouped under an Application from the IAM/auth service.
/// applicationId is a cross-service reference — no FK constraint (different DB).
model Plan {
  id            String       @id @default(uuid())
  tenantId      String
  /// ID of the Application in the auth service this plan belongs to.
  /// Use GET /subscriptions/plans?applicationId=xxx to list plans for one app.
  applicationId String?
  name          String
  description   String?
  amount        BigInt       // recurring charge per interval
  currency      String       @default("INR")
  interval      PlanInterval
  intervalCount Int          @default(1) // e.g. every 2 months
  trialDays     Int          @default(0)
  isActive      Boolean      @default(true)
  metadata      Json?        @db.JsonB
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscriptions Subscription[]

  @@index([tenantId])
  @@index([tenantId, applicationId])
}

/// Customer subscription — tracks lifecycle and renewal windows.
model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String
  customerId         String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  cancelReason       String?
  trialStart         DateTime?
  trialEnd           DateTime?
  metadata           Json?              @db.JsonB
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  plan   Plan               @relation(fields: [planId], references: [id])
  cycles SubscriptionCycle[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([status])
  @@index([currentPeriodEnd])
}

/// One billing cycle per subscription period — tracks renewal attempts.
model SubscriptionCycle {
  id             String      @id @default(uuid())
  subscriptionId String
  periodStart    DateTime
  periodEnd      DateTime
  amount         BigInt
  currency       String
  status         CycleStatus @default(PENDING)
  invoiceId      String?
  transactionId  String?
  /// Number of collection attempts made
  attemptCount   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
}

// ─── Audit Models ─────────────────────────────────────────────────────────────

/// Immutable financial audit log — append-only, never updated or deleted.
model AuditLog {
  id            String    @id @default(uuid())
  tenantId      String
  /// Who performed the action (userId, systemProcess, etc.)
  actor         String
  /// Verb: PAYMENT_INITIATED, REFUND_PROCESSED, SUBSCRIPTION_RENEWED, etc.
  action        String
  resourceType  String
  resourceId    String
  transactionId String?
  oldState      Json?     @db.JsonB
  newState      Json?     @db.JsonB
  metadata      Json?     @db.JsonB
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([tenantId])
  @@index([resourceType, resourceId])
  @@index([transactionId])
  @@index([actor])
  @@index([createdAt])
}
